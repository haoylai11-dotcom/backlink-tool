{
  "manifest_version": 3,
  "name": "Backlink Comment Tool",
  "version": "1.0.0",
  "description": "Automated blog comment backlink builder with Semrush integration",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": ["https://api.ahrefs.com/*", "<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Backlink Tool"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
